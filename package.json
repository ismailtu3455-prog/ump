{
  "name": "universal-media-player",
  "version": "2.3.0",
  "description": "Modern universal media player for video, audio and images",
  "main": "public/main.js",
  "author": "Media Player Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node -e \"require('fs').copyFileSync('public/Untitled Project (1).jpg', 'build/icon.png'); console.log('Icon copied');\"",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win --publish never",
    "electron:preview": "electron .",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "clsx": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
    "ytmusic-api": "^5.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mediaplayer.app",
    "productName": "Universal Media Player",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "build/**/*",
      "public/main.js",
      "public/preload.js"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build"
      }
    ],
    "fileAssociations": [
      {
        "ext": "mp4",
        "name": "MP4 Video",
        "description": "MPEG-4 Video",
        "mimeType": "video/mp4",
        "role": "Viewer"
      },
      {
        "ext": "webm",
        "name": "WebM Video",
        "description": "WebM Video",
        "mimeType": "video/webm",
        "role": "Viewer"
      },
      {
        "ext": "mkv",
        "name": "MKV Video",
        "description": "Matroska Video",
        "mimeType": "video/x-matroska",
        "role": "Viewer"
      },
      {
        "ext": "avi",
        "name": "AVI Video",
        "description": "Audio Video Interleave",
        "mimeType": "video/x-msvideo",
        "role": "Viewer"
      },
      {
        "ext": "mov",
        "name": "MOV Video",
        "description": "QuickTime Movie",
        "mimeType": "video/quicktime",
        "role": "Viewer"
      },
      {
        "ext": "mp3",
        "name": "MP3 Audio",
        "description": "MPEG Audio Layer 3",
        "mimeType": "audio/mpeg",
        "role": "Viewer"
      },
      {
        "ext": "wav",
        "name": "WAV Audio",
        "description": "Waveform Audio",
        "mimeType": "audio/x-wav",
        "role": "Viewer"
      },
      {
        "ext": "flac",
        "name": "FLAC Audio",
        "description": "Free Lossless Audio Codec",
        "mimeType": "audio/flac",
        "role": "Viewer"
      },
      {
        "ext": "jpg",
        "name": "JPEG Image",
        "description": "JPEG Image",
        "mimeType": "image/jpeg",
        "role": "Viewer"
      },
      {
        "ext": "png",
        "name": "PNG Image",
        "description": "Portable Network Graphics",
        "mimeType": "image/png",
        "role": "Viewer"
      },
      {
        "ext": "webp",
        "name": "WebP Image",
        "description": "WebP Image",
        "mimeType": "image/webp",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "runAfterFinish": true
    }
  }
}
